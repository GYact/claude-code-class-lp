# Resend (https://resend.com) — メール通知用
# 本番は gugenlab.com のドメイン認証（SPF/DKIM）を完了させてから noreply@gugenlab.com を使う
# 初期テストは Resend の共用アドレス onboarding@resend.dev が使える（ドメイン認証不要）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="Claude Code教室 <onboarding@resend.dev>"

# 申込通知の送付先
NOTIFY_TO_EMAIL=yukito.go@gugenlab.com

# Slack Incoming Webhook URL（ワークスペース設定 → App → Incoming Webhooks から発行）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXX/YYYYYYYY/ZZZZZZZZZZZZZZZZZZ
